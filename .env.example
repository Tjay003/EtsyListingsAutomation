# Copy this file to .env, then fill in your private keys.
# Never commit the real .env file.

# Product copywriting and image/spec analysis
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-latest

# Optional copywriting fallback / tweak model
OPEN_AI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# AI image-to-image generation through Fal.ai
# Default image model in the app is Flux Kontext Pro.
FAL_KEY=your_fal_key_here
FAL_MODEL=fal-ai/flux-pro/kontext

# Local output base folder. The app creates one subfolder per workspace token.
OUTPUT_DIR=%USERPROFILE%\Downloads\AliExpressQueue

# Keep false for normal local installs.
HOSTED_MODE=false

# Optional fallback if no Fal.ai key is configured.
USE_FREE_GENERATOR=false
