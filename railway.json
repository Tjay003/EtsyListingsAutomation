{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "sh -c \"python -m uvicorn src.server:app --host 0.0.0.0 --port ${PORT:-8000}\"",
    "healthcheckPath": "/api/settings",
    "restartPolicyType": "ON_FAILURE"
  }
}
